// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(uuid())
  phone           String   @unique
  name            String?
  defaultAddress  String?
  landmark        String?
  instructions    String?
  orders          Order[]
  addresses       Address[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Address {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label            String   @default("Other") // Home, Work, Other
  formattedAddress String
  houseNumber      String?
  landmark         String?
  instructions     String?
  latitude         Float
  longitude        Float
  isDefault        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}


model Order {
  id              String      @id @default(uuid())
  userId          String?
  user            User?       @relation(fields: [userId], references: [id])
  customerName         String
  customerPhone        String
  customerAddress      String?
  formattedAddress     String?
  houseNumber          String?
  floor                String?
  landmark             String?
  deliveryInstructions String?
  latitude             Float?
  longitude            Float?
  distanceKm           Float?
  deliveryDistance     Float?
  totalAmount          Float
  deliveryFee          Float       @default(0)
  deliveryCharge       Float?
  status               String      @default("PENDING") // PENDING, MODIFICATION_REQUESTED, APPROVED, OUT_FOR_DELIVERY, DELIVERED, CANCELLED
  isAcknowledged       Boolean     @default(false)
  items                OrderItem[]
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
}

model OrderItem {
  id           String  @id @default(uuid())
  orderId      String
  order        Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  itemId       String
  itemName     String
  quantity     Int
  price        Float
  status       String  @default("AVAILABLE") // AVAILABLE, UNAVAILABLE, REPLACED
  replacedWith String? // Name of replacement item
}
